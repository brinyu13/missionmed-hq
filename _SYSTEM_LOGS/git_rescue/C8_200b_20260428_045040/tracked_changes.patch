+/* TOAST */
+function toast(i,m){const c=document.getElementById('toast-c'),t=document.createElement('div');t.className='toast';t.innerHTML='<span style="font-size:1rem">'+i+'</span> '+m;c.appendChild(t);setTimeout(()=>{if(t.parentNode)t.remove()},3200);}
+
+/* DEMO STATE - uses top-bar-center if we add state btns, for now via keyboard */
+
+/* MODAL */
+function showModal(h){document.getElementById('modal-c').innerHTML=h;document.getElementById('modal-ov').classList.add('show');}
+function closeM(){document.getElementById('modal-ov').classList.remove('show');}
