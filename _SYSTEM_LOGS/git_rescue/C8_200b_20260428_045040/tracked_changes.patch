+  document.getElementById('remain-lbl').textContent=TASKS.filter(t=>t.st!=='completed').length+' remaining';
+}
+
+/* TODAY TASKS */
+function renderToday(){
+  const el=document.getElementById('today-task-list');let h='';
+  TASKS.forEach((t,i)=>{
+    const d=t.st==='completed';
+    h+='<div class="task-row'+(d?' completed':'')+'"><div class="task-color" style="background:'+t.c+'"></div><div class="task-info"><div class="task-name">'+t.n+'</div><div class="task-meta">'+t.tp+' &middot; '+t.ty+'</div></div><div class="task-duration">'+t.dur+'m</div><div class="task-actions">'+(d?'<span style="color:var(--mastery-stable);font-size:0.62rem;font-weight:700;font-family:var(--font-display)">DONE</span>':'<button class="btn-sm btn-success" onclick="compTask('+i+')">Done</button><button class="btn-sm" onclick="startTimer(\''+t.n.replace(/'/g,"\\'")+'\',\''+t.tp+'\','+t.dur+')">Start</button>')+'</div></div>';
+  });el.innerHTML=h;
+}
+
+/* TASK QUEUE */
+function renderTQ(){
+  const el=document.getElementById('task-queue');let h='';
+  TASKS.forEach((t,i)=>{
+    const d=t.st==='completed';
+    h+='<div class="task-queue-item'+(d?' task-completed':'')+'"><div class="tq-status-dot '+(d?'completed':'pending')+'"></div><div style="width:3px;height:28px;border-radius:2px;background:'+t.c+';flex-shrink:0"></div><div class="tq-info"><div class="tq-name">'+t.n+'</div><div class="tq-meta">'+t.tp+' &middot; '+t.ty+' &middot; '+t.r+'</div></div><div class="tq-dur">'+t.dur+'m</div><div class="tq-actions">'+(d?'<span style="color:var(--mastery-stable);font-size:0.62rem;font-weight:700;font-family:var(--font-display)">DONE</span>':'<button class="btn-sm btn-success" onclick="compTask('+i+')">Done</button><button class="btn-sm" onclick="startTimer(\''+t.n.replace(/'/g,"\\'")+'\',\''+t.tp+'\','+t.dur+')">Start</button><button class="btn-sm" onclick="reschedTask('+i+')">Move</button>')+'</div></div>';
+  });el.innerHTML=h;
+  const dn=TASKS.filter(t=>t.st==='completed').length;
+  document.getElementById('tq-count').textContent=dn+' / '+TASKS.length+' complete';
+}
+function compTask(i){if(TASKS[i].st==='completed')return;TASKS[i].st='completed';done++;xp+=40;upProg();renderToday();renderTQ();toast('\u{1F3C6}','Task complete. +40 XP.');if(TASKS.every(t=>t.st==='completed'))setTimeout(()=>toast('\u{1F451}','All tasks complete. Outstanding work today.'),600);}
+function reschedTask(i){showModal('<h3>Reschedule: '+TASKS[i].n+'</h3><div class="subtitle">'+TASKS[i].tp+' &middot; '+TASKS[i].dur+' min</div><p style="font-size:0.82rem;color:var(--text-secondary);margin-bottom:12px">Move this block or recover it tomorrow. No pressure.</p><div class="modal-actions"><button class="btn-sm btn-success" onclick="toast(\'\u2705\',\'Moved to later today.\');closeM();">Later Today</button><button class="btn-sm" onclick="toast(\'\u2705\',\'Moved to tomorrow.\');closeM();">Tomorrow</button><button class="btn-sm" onclick="toast(\'\u2705\',\'Week rebalanced.\');closeM();">Rebalance</button><button class="btn-sm btn-danger" onclick="closeM()">Cancel</button></div>');}
+
+/* PLANNER */
+function renderPlanner(){
+  const g=document.getElementById('planner-grid');g.innerHTML='';
+  g.innerHTML+='<div class="planner-time-label"></div>';
+  DAYS.forEach((d,i)=>g.innerHTML+='<div class="planner-day-header'+(i===0?' today':'')+'">'+d+'</div>');
+  SLOTS.forEach((sl,si)=>{
+    g.innerHTML+='<div class="planner-time-label">'+sl+'</div>';
+    DAYS.forEach((dy,di)=>{
+      const cell=document.createElement('div');cell.className='planner-cell';cell.dataset.d=di;cell.dataset.s=si;
+      cell.addEventListener('dragover',function(e){e.preventDefault();this.classList.add('drag-over');});
+      cell.addEventListener('dragleave',function(){this.classList.remove('drag-over');});
+      cell.addEventListener('drop',function(e){dropB(e,this);});
+      PB.filter(b=>b.d===di&&b.s===si).forEach(b=>{
+        const bl=document.createElement('div');bl.className='planner-block'+(b.g?' ghost-block':'');
+        bl.style.borderLeftColor=b.c;bl.style.background=CBG[b.c]||'rgba(79,124,255,0.1)';
+        bl.draggable=true;
+        bl.addEventListener('dragstart',function(e){e.dataTransfer.setData('text/plain',JSON.stringify(b));this.style.opacity='0.4';});
+        bl.addEventListener('dragend',function(){this.style.opacity='1';});
+        bl.addEventListener('click',function(){openBlock(b);});
+        bl.innerHTML='<div class="block-topic">'+(b.g?'\u{1F47B} ':'')+b.tp+'</div><div class="block-type">'+b.ty+(b.dur?' &middot; '+b.dur:'')+'</div>';
+        cell.appendChild(bl);
+      });g.appendChild(cell);
+    });
+  });
+}
+function dropB(e,cell){e.preventDefault();cell.classList.remove('drag-over');let n='';try{n=JSON.parse(e.dataTransfer.getData('text/plain')).tp;}catch{n=e.dataTransfer.getData('text/plain');}if(n){toast('\u{1F4CB}',n+' moved to '+DAYS[cell.dataset.d]+' '+SLOTS[cell.dataset.s].toLowerCase()+'.');const bl=document.createElement('div');bl.className='planner-block';bl.style.borderLeftColor='var(--accent-1)';bl.style.background='rgba(255,255,255,0.06)';bl.innerHTML='<div class="block-topic">'+n+'</div><div class="block-type">Scheduled</div>';cell.appendChild(bl);}}
+function dragU(e,n){e.dataTransfer.setData('text/plain',n);}
+function openBlock(b){showModal('<h3>'+(b.g?'\u{1F47B} Ghost: ':'')+b.tp+' '+b.ty+'</h3><div class="subtitle">'+(b.dur||'Suggested')+(b.g?' &middot; Advisor suggestion':' &middot; '+SLOTS[b.s]+' &middot; '+DAYS[b.d])+'</div>'+(b.g&&b.adv?'<p style="font-size:0.82rem;color:var(--accent-3);margin-bottom:8px">'+b.adv+'</p>':'')+'<p style="font-size:0.82rem;color:var(--text-secondary);margin-bottom:12px">'+(b.g?'Accept to add to your plan.':'Targets '+b.tp+' with '+b.ty.toLowerCase()+' practice.')+'</p><div class="modal-actions">'+(b.g?'<button class="btn-sm btn-success" onclick="toast(\'\u2705\',\'Accepted.\');closeM();">Accept</button><button class="btn-sm btn-danger" onclick="toast(\'\u274C\',\'Removed.\');closeM();">Reject</button>':'<button class="btn-primary" style="font-size:0.72rem;padding:6px 16px" onclick="startTimer(\''+b.tp+' '+b.ty+'\',\''+b.tp+'\','+(parseInt(b.dur)||20)+');closeM();">Start Timer</button><button class="btn-sm btn-success" onclick="xp+=40;done++;upProg();toast(\'\u2705\',\'+40 XP\');closeM();">Complete</button><button class="btn-sm" onclick="toast(\'\u{1F4CB}\',\'Rescheduled.\');closeM();">Move</button><button class="btn-sm" onclick="toast(\'\u{1F4C5}\',\'Exported.\');closeM();">Calendar</button>')+'<button class="btn-sm btn-danger" onclick="closeM()">Close</button></div>');}
+function recoverTask(a){const m={today:'Endocrine drill recovered for today.',tomorrow:'Moved to tomorrow morning.',rebalance:'Week rebalanced.'};toast('\u2705',m[a]);document.getElementById('rec-item').style.opacity='0.25';document.getElementById('rec-item').style.pointerEvents='none';}
+
+/* ADVISOR */
+function advAct(i,a){
+  const c=document.getElementById('adv-'+i);
+  if(a==='accept'){c.classList.add('accepted');c.querySelector('.advisor-actions').innerHTML='<span style="color:var(--mastery-stable);font-size:0.72rem;font-weight:700;font-family:var(--font-display)">ACCEPTED</span>';toast('\u2705','Suggestion accepted. Block added.');updBadge();}
+  else if(a==='reject'){c.classList.add('rejected');c.querySelector('.advisor-actions').innerHTML='<span style="color:var(--text-muted);font-size:0.72rem">Removed.</span>';toast('\u{1F44D}','Removed. Plan unchanged.');updBadge();}
+  else if(a==='modify'){showModal('<h3>Modify Suggestion</h3><div class="subtitle">Adjust to fit your schedule.</div><div style="margin:12px 0"><label style="font-size:0.72rem;color:var(--text-secondary);display:block;margin-bottom:4px">Time</label><select style="width:100%;padding:6px 10px;background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-sm);color:var(--text-primary);font-size:0.82rem;font-family:var(--font-body)"><option>Morning</option><option>Midday</option><option selected>Afternoon</option><option>Evening</option></select></div><div style="margin:12px 0"><label style="font-size:0.72rem;color:var(--text-secondary);display:block;margin-bottom:4px">Duration</label><select style="width:100%;padding:6px 10px;background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-sm);color:var(--text-primary);font-size:0.82rem;font-family:var(--font-body)"><option>10 min</option><option>15 min</option><option selected>20 min</option><option>30 min</option></select></div><div class="modal-actions"><button class="btn-primary" style="font-size:0.72rem;padding:6px 16px" onclick="toast(\'\u2705\',\'Modified + accepted.\');closeM();">Accept Modified</button><button class="btn-sm btn-danger" onclick="closeM()">Cancel</button></div>');}
+}
+function advWhy(i){const r=document.getElementById('adv-r-'+i);r.style.display=r.style.display==='block'?'none':'block';}
+function updBadge(){const n=document.querySelectorAll('.advisor-card:not(.accepted):not(.rejected)').length;const b=document.querySelector('.nav-badge');if(b)b.textContent=n;}
+
+/* PERFORMANCE */
+function renderPerf(){
+  const g=document.getElementById('perf-grid');let h='';
+  TOPICS.forEach(t=>{
+    const ti=t.t==='up'?'\u2191':t.t==='down'?'\u2193':'\u2192';
+    const tc=t.t==='up'?'trend-up':t.t==='down'?'trend-down':'';
+    h+='<div class="topic-card card"><div class="topic-top"><div><div class="topic-name">'+t.n+'</div><span class="tag tag-'+t.s+'">'+t.s+'</span></div><div class="topic-accuracy" style="color:'+t.c+'">'+t.a+'%</div></div><div class="topic-bar-track"><div class="topic-bar-fill" style="width:'+t.a+'%;background:'+t.c+'"></div></div><div class="topic-details"><span>'+t.q+' Qs</span><span>'+t.conf+'</span><span class="'+tc+'">'+ti+' '+t.t+'</span></div></div>';
+  });g.innerHTML=h;
+}
+
+/* TIMER */
+let tInt=null,tSec=0,tTot=0,tPaused=false,tName='';
+function startTimer(n,tp,m){tName=n;tSec=m*60;tTot=tSec;tPaused=false;document.getElementById('t-name').textContent=n;document.getElementById('t-topic').textContent=tp;document.getElementById('t-pause').textContent='Pause';document.getElementById('timer-overlay').classList.add('show');upTimer();clearInterval(tInt);tInt=setInterval(()=>{if(!tPaused){tSec--;upTimer();if(tSec<=0)completeTimer();}},1000);}
+function upTimer(){const m=Math.floor(Math.max(tSec,0)/60),s=Math.max(tSec,0)%60;document.getElementById('t-display').textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');const ci=2*Math.PI*45,off=ci*(1-Math.max(tSec,0)/tTot);document.getElementById('t-ring').style.strokeDashoffset=off;}
+function togglePause(){tPaused=!tPaused;document.getElementById('t-pause').textContent=tPaused?'Resume':'Pause';}
+function completeTimer(){clearInterval(tInt);document.getElementById('timer-overlay').classList.remove('show');xp+=40;done++;upProg();toast('\u{1F3C6}',tName+' complete. +40 XP.');const p=TASKS.find(t=>t.st==='pending');if(p)setTimeout(()=>toast('\u27A1\uFE0F','Next: '+p.n+' ('+p.dur+'m)'),800);}
+function stopTimer(){clearInterval(tInt);document.getElementById('timer-overlay').classList.remove('show');toast('\u23F9\uFE0F','Timer stopped.');}
+
+/* CALENDAR MODAL */
+function openCalModal(){showModal('<h3>Export to Calendar</h3><div class="subtitle">Put your study blocks on your phone.</div><div style="margin:12px 0"><div style="font-size:0.72rem;color:var(--text-secondary);margin-bottom:6px">Scope</div><div style="display:flex;gap:6px;flex-wrap:wrap"><button class="btn-sm" onclick="toast(\'\u2705\',\'Today exported.\');closeM();">Today</button><button class="btn-sm" onclick="toast(\'\u2705\',\'Week exported.\');closeM();">This Week</button><button class="btn-sm" onclick="toast(\'\u2705\',\'Full plan exported.\');closeM();">Full Plan</button></div></div><div style="margin:12px 0"><div style="font-size:0.72rem;color:var(--text-secondary);margin-bottom:6px">Destination</div><div style="display:flex;gap:6px;flex-wrap:wrap"><button class="btn-secondary" onclick="toast(\'\u2705\',\'Downloaded .ics\');closeM();">.ics File</button><button class="btn-secondary" onclick="toast(\'\u{1F310}\',\'Google Calendar\');closeM();">Google</button><button class="btn-secondary" onclick="toast(\'\u{1F34E}\',\'Apple Calendar\');closeM();">Apple</button><button class="btn-secondary" onclick="copyFeed();closeM();">Feed URL</button></div></div><div class="modal-actions"><button class="btn-sm btn-danger" onclick="closeM()">Close</button></div>');}
+function copyFeed(){toast('\u{1F517}','Feed URL copied. Add to Apple or Google Calendar.');}
+
+/* INIT */
+renderToday();renderPlanner();renderPerf();renderTQ();
+</script>
 </body>
 </html>
