+  --ghost-glow: rgba(0,255,240,0.15);
+  --ghost-border: rgba(0,255,240,0.4);
+  --font-display: 'Russo One', sans-serif;
+  --font-body: 'Fredoka', sans-serif;
+  --glow-1: 0 0 20px rgba(0,255,240,0.3);
+  --glow-2: 0 0 20px rgba(57,255,20,0.3);
+  --gradient-hero: linear-gradient(135deg, #041a28 0%, #0a3550 50%, #041a28 100%);
+  --gradient-accent: linear-gradient(135deg, #00fff0, #39ff14);
+  --gradient-btn: linear-gradient(135deg, #00fff0, #00bfff);
+  --card-border-style: 2px solid;
+  --skew: 0deg;
+}
+
+/* THEME 4: ARCADE MODE (Fun Gamer) */
+[data-theme="arcade-mode"] {
+  --bg-deep: #1a0a2e;
+  --bg-panel: #261345;
+  --bg-card: rgba(45,20,85,0.8);
+  --bg-surface: rgba(35,15,70,0.85);
+  --border-subtle: rgba(255,60,172,0.12);
+  --border-glow: rgba(255,60,172,0.35);
+  --text-primary: #fff0fa;
+  --text-secondary: #d8a8e8;
+  --text-muted: #9060b0;
+  --accent-1: #ff3cac;
+  --accent-2: #a8ff3c;
+  --accent-3: #ff6b35;
+  --accent-4: #3c9dff;
+  --ghost-glow: rgba(168,255,60,0.15);
+  --ghost-border: rgba(168,255,60,0.4);
+  --font-display: 'Bangers', cursive;
+  --font-body: 'Fredoka', sans-serif;
+  --glow-1: 0 0 20px rgba(255,60,172,0.3);
+  --glow-2: 0 0 20px rgba(168,255,60,0.3);
+  --gradient-hero: linear-gradient(135deg, #1a0a2e 0%, #3d1570 50%, #1a0a2e 100%);
+  --gradient-accent: linear-gradient(135deg, #ff3cac, #a8ff3c);
+  --gradient-btn: linear-gradient(135deg, #ff3cac, #ff6b35);
+  --card-border-style: 3px solid;
+  --skew: 0deg;
+}
+
+/* ============================================================
+   RESET + BASE
+   ============================================================ */
+*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
+html, body { height: 100%; overflow: hidden; }
+body {
+  font-family: var(--font-body);
+  background: var(--bg-deep);
+  color: var(--text-primary);
+  -webkit-font-smoothing: antialiased;
+  transition: background 0.4s ease, color 0.3s ease;
+}
+button { cursor: pointer; font-family: var(--font-body); border: none; background: none; color: inherit; }
+
+/* ============================================================
+   SHELL: ZERO-SCROLL VIEWPORT FIT
+   ============================================================ */
+.app-shell {
+  display: grid;
+  grid-template-columns: 56px 1fr;
+  grid-template-rows: 52px 1fr;
+  height: 100vh;
+  width: 100vw;
+  overflow: hidden;
+}
+
+/* TOP BAR */
+.top-bar {
+  grid-column: 1 / -1;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 0 16px;
+  background: var(--bg-panel);
+  border-bottom: var(--card-border-style) var(--border-subtle);
+  z-index: 100;
+  gap: 8px;
+}
+.top-bar-left { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
+.logo {
+  font-family: var(--font-display);
+  font-size: 1.3rem;
+  font-weight: 900;
+  letter-spacing: 2px;
+  background: var(--gradient-accent);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  text-transform: uppercase;
+}
+.logo-sub {
+  font-family: var(--font-display);
+  font-size: 0.55rem;
+  color: var(--accent-1);
+  letter-spacing: 3px;
+  text-transform: uppercase;
+  opacity: 0.8;
+}
+.top-bar-center { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
+.top-bar-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
+
+/* Theme toggle */
+.theme-toggle {
+  display: flex;
+  background: var(--bg-surface);
+  border-radius: 20px;
+  padding: 2px;
+  border: 1px solid var(--border-subtle);
+  gap: 2px;
+}
+.theme-btn {
+  padding: 4px 10px;
+  font-size: 0.6rem;
+  font-weight: 700;
+  font-family: var(--font-display);
+  border-radius: 18px;
+  color: var(--text-muted);
+  transition: var(--transition);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+  white-space: nowrap;
+}
+.theme-btn.active { background: var(--gradient-btn); color: #fff; }
+.theme-btn:hover:not(.active) { color: var(--text-primary); }
+
+/* User area */
+.user-pill {
+  display: flex; align-items: center; gap: 6px;
+  padding: 3px 10px 3px 3px;
+  background: var(--bg-card);
+  border-radius: 20px;
+  border: 1px solid var(--border-subtle);
+}
+.user-avatar {
+  width: 26px; height: 26px;
+  border-radius: 50%;
+  background: var(--gradient-btn);
+  display: flex; align-items: center; justify-content: center;
+  font-size: 0.6rem; font-weight: 900; color: #fff;
+  font-family: var(--font-display);
+}
+.user-name { font-size: 0.72rem; font-weight: 700; }
+.user-level { font-size: 0.58rem; color: var(--accent-1); font-weight: 700; font-family: var(--font-display); }
+.streak-badge {
+  display: flex; align-items: center; gap: 3px;
+  padding: 3px 8px;
+  background: rgba(255,215,0,0.12);
+  border: 1px solid rgba(255,215,0,0.3);
+  border-radius: 14px;
+  font-size: 0.68rem; font-weight: 700;
+  color: #ffd700;
+  font-family: var(--font-display);
+}
+.xp-mini { font-size: 0.68rem; color: var(--accent-1); font-weight: 700; font-family: var(--font-display); }
+
+/* SIDE NAV */
+.side-nav {
+  background: var(--bg-panel);
+  border-right: 1px solid var(--border-subtle);
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  padding: 8px 0;
+  gap: 2px;
+  z-index: 90;
+}
+.nav-btn {
+  width: 40px; height: 40px;
+  border-radius: var(--radius-md);
+  display: flex; align-items: center; justify-content: center;
+  color: var(--text-muted);
+  transition: var(--transition);
+  position: relative;
+}
+.nav-btn:hover { background: rgba(255,255,255,0.05); color: var(--text-secondary); }
+.nav-btn.active { color: var(--accent-1); }
+.nav-btn.active::before {
+  content: '';
+  position: absolute; left: 0; top: 50%; transform: translateY(-50%);
+  width: 3px; height: 22px;
+  background: var(--gradient-accent);
+  border-radius: 0 3px 3px 0;
+}
+.nav-btn svg { width: 18px; height: 18px; }
+.nav-badge {
+  position: absolute; top: 2px; right: 2px;
+  width: 15px; height: 15px;
+  background: var(--accent-2);
+  border-radius: 50%;
+  font-size: 0.5rem; font-weight: 900; color: #000;
+  display: flex; align-items: center; justify-content: center;
+  font-family: var(--font-display);
+}
+.nav-tip {
+  display: none;
+  position: absolute; left: 50px; top: 50%; transform: translateY(-50%);
+  padding: 3px 8px; background: var(--bg-card); border: 1px solid var(--border-glow);
+  border-radius: var(--radius-sm);
+  font-size: 0.65rem; font-weight: 600; white-space: nowrap; z-index: 200;
+}
+.nav-btn:hover .nav-tip { display: block; }
+
+/* MAIN */
+.main-content {
+  overflow: hidden;
+  padding: 10px;
+  display: flex;
+  flex-direction: column;
+}
+.section { display: none; flex: 1; overflow: hidden; animation: fadeIn 0.3s ease; }
+.section.active { display: flex; flex-direction: column; }
+@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
+
+/* ============================================================
+   COMMON
+   ============================================================ */
+.card {
+  background: var(--bg-card);
+  border: var(--card-border-style) var(--border-subtle);
+  border-radius: var(--radius-lg);
+  padding: 12px;
+  transition: var(--transition);
+  backdrop-filter: blur(8px);
+}
+.card:hover { border-color: var(--border-glow); box-shadow: var(--glow-1); }
+.card-title {
+  font-family: var(--font-display);
+  font-size: 0.62rem;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 2px;
+  color: var(--accent-1);
+}
+.section-title {
+  font-family: var(--font-display);
+  font-size: 1.3rem;
+  font-weight: 900;
+  text-transform: uppercase;
+  letter-spacing: 2px;
+  background: var(--gradient-accent);
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+}
+
+.btn-primary {
+  display: inline-flex; align-items: center; gap: 6px;
+  padding: 8px 20px;
+  background: var(--gradient-btn);
+  color: #fff;
+  border-radius: var(--radius-md);
+  font-family: var(--font-display);
+  font-size: 0.78rem; font-weight: 700;
+  letter-spacing: 1px;
+  text-transform: uppercase;
+  transition: var(--transition);
+  box-shadow: var(--glow-1);
+}
+.btn-primary:hover { transform: translateY(-2px) scale(1.02); box-shadow: var(--glow-1), var(--glow-2); }
+.btn-secondary {
+  display: inline-flex; align-items: center; gap: 5px;
+  padding: 5px 12px;
+  background: var(--bg-surface);
+  border: 1px solid var(--border-subtle);
+  color: var(--text-secondary);
+  border-radius: var(--radius-sm);
+  font-size: 0.7rem; font-weight: 600;
+  transition: var(--transition);
+}
+.btn-secondary:hover { border-color: var(--accent-1); color: var(--accent-1); }
+.btn-sm {
+  padding: 4px 10px;
+  font-size: 0.65rem; font-weight: 700;
+  border-radius: var(--radius-sm);
+  border: 1px solid var(--border-subtle);
+  color: var(--text-secondary);
+  transition: var(--transition);
+  font-family: var(--font-display);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+}
+.btn-sm:hover { border-color: var(--accent-1); color: var(--accent-1); }
+.btn-success { border-color: rgba(46,213,115,0.4); color: var(--mastery-stable); }
+.btn-success:hover { border-color: var(--mastery-stable); background: rgba(46,213,115,0.1); }
+.btn-danger { border-color: rgba(255,71,87,0.3); color: var(--mastery-critical); }
+.btn-danger:hover { border-color: var(--mastery-critical); background: rgba(255,71,87,0.1); }
+.btn-ghost {
+  padding: 4px 10px; font-size: 0.65rem; font-weight: 700;
+  color: var(--accent-3);
+  border: 1px solid var(--ghost-border);
+  border-radius: var(--radius-sm);
+  background: var(--ghost-glow);
+  font-family: var(--font-display);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+}
+
+.tag {
+  display: inline-flex; padding: 1px 7px; border-radius: 8px;
+  font-size: 0.55rem; font-weight: 900; text-transform: uppercase;
+  letter-spacing: 0.5px;
+  font-family: var(--font-display);
+}
+.tag-critical { background: rgba(255,71,87,0.2); color: var(--mastery-critical); }
+.tag-weak { background: rgba(255,159,67,0.2); color: var(--mastery-weak); }
+.tag-moderate { background: rgba(254,202,87,0.2); color: var(--mastery-moderate); }
+.tag-stable { background: rgba(46,213,115,0.2); color: var(--mastery-stable); }
+.tag-strong { background: rgba(30,144,255,0.2); color: var(--mastery-strong); }
+
+/* Toast */
+.toast-container { position: fixed; bottom: 16px; right: 16px; z-index: 9999; display: flex; flex-direction: column-reverse; gap: 6px; }
+.toast {
+  padding: 10px 16px;
+  background: var(--bg-panel);
+  border: 2px solid var(--accent-1);
+  border-radius: var(--radius-md);
+  font-size: 0.78rem; font-weight: 600;
+  color: var(--text-primary);
+  box-shadow: var(--glow-1);
+  animation: toastIn 0.3s ease, toastOut 0.3s ease 2.7s forwards;
+  display: flex; align-items: center; gap: 6px;
+  font-family: var(--font-body);
+}
+@keyframes toastIn { from { opacity:0; transform:translateY(16px) scale(0.95); } to { opacity:1; transform:translateY(0) scale(1); } }
+@keyframes toastOut { from { opacity:1; } to { opacity:0; transform:translateY(-8px); } }
+
+/* Modal */
+.modal-overlay {
+  position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(6px);
+  z-index: 1000; display: none; align-items: center; justify-content: center;
+}
+.modal-overlay.show { display: flex; }
+.modal {
+  background: var(--bg-panel); border: 2px solid var(--border-glow);
+  border-radius: var(--radius-xl); padding: 24px;
+  max-width: 480px; width: 90%; max-height: 80vh; overflow-y: auto;
+  box-shadow: var(--glow-1);
+}
+.modal h3 { font-family: var(--font-display); font-size: 1rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
+.modal .subtitle { font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 14px; }
+.modal-actions { display: flex; gap: 6px; margin-top: 14px; flex-wrap: wrap; }
+
+/* ============================================================
+   COMMAND CENTER (zero-scroll grid)
+   ============================================================ */
+.cmd-grid {
+  flex: 1;
+  display: grid;
+  grid-template-columns: 1fr 300px;
+  grid-template-rows: auto 1fr auto;
+  gap: 10px;
+  min-height: 0;
+  overflow: hidden;
+}
+.cmd-mission {
+  grid-column: 1; grid-row: 1;
+  background: var(--gradient-hero);
+  border: var(--card-border-style) var(--border-glow);
+  border-radius: var(--radius-xl);
+  padding: 16px 20px;
+  position: relative;
+  overflow: hidden;
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+}
+.cmd-mission::before {
+  content: '';
+  position: absolute; top: -40%; right: -15%;
+  width: 250px; height: 250px;
+  background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
+}
+.cmd-mission::after {
+  content: '';
+  position: absolute; bottom: 0; left: 0; right: 0;
+  height: 2px;
+  background: var(--gradient-accent);
+}
+.mission-label {
+  font-family: var(--font-display);
+  font-size: 0.6rem; font-weight: 700;
+  text-transform: uppercase; letter-spacing: 3px;
+  color: var(--accent-1);
+  margin-bottom: 6px;
+  display: flex; align-items: center; gap: 6px;
+}
+.pulse-dot {
+  width: 6px; height: 6px; border-radius: 50%;
+  background: var(--accent-1);
+  animation: pulse 2s ease-in-out infinite;
+}
+@keyframes pulse { 0%,100% { opacity:1; box-shadow:0 0 4px var(--accent-1); } 50% { opacity:0.4; box-shadow:0 0 12px var(--accent-1); } }
+.mission-title {
+  font-family: var(--font-display);
+  font-size: 1.5rem; font-weight: 900;
+  text-transform: uppercase; letter-spacing: 1px;
+  margin-bottom: 4px; line-height: 1.15;
+}
+.topic-hl { color: var(--accent-1); }
+.mission-why { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.45; margin-bottom: 10px; max-width: 550px; }
+.mission-stats { display: flex; gap: 16px; margin-bottom: 12px; flex-wrap: wrap; }
+.mission-stat { display: flex; flex-direction: column; gap: 1px; }
+.mission-stat-val { font-family: var(--font-display); font-size: 1rem; font-weight: 900; }
+.mission-stat-label { font-size: 0.55rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
+
+/* Sidebar */
+.cmd-sidebar {
+  grid-column: 2; grid-row: 1 / 4;
+  display: flex; flex-direction: column; gap: 8px;
+  min-height: 0; overflow-y: auto;
+  scrollbar-width: none;
+}
+.cmd-sidebar::-webkit-scrollbar { display: none; }
+
+.progress-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 8px; }
+.prog-item { text-align: center; }
+.prog-value { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; }
+.prog-label { font-size: 0.52rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 1px; }
+.xp-bar-wrap { margin-top: 8px; background: rgba(255,255,255,0.06); border-radius: 6px; height: 7px; overflow: hidden; }
+.xp-bar-fill { height: 100%; background: var(--gradient-accent); border-radius: 6px; transition: width 0.6s ease; }
+.xp-label { display: flex; justify-content: space-between; font-size: 0.55rem; color: var(--text-muted); margin-top: 3px; }
+.weekly-bar-track { flex:1; height:5px; background:rgba(255,255,255,0.06); border-radius:4px; overflow:hidden; }
+.weekly-bar-fill { height:100%; background:var(--gradient-accent); border-radius:4px; }
+
+.advisor-alert-card {
+  background: var(--ghost-glow); border: 2px solid var(--ghost-border);
+  border-radius: var(--radius-lg); padding: 12px;
+  cursor: pointer; transition: var(--transition);
+}
+.advisor-alert-card:hover { box-shadow: var(--glow-2); }
+.advisor-count { font-family: var(--font-display); font-size: 1.4rem; font-weight: 900; color: var(--accent-3); }
+.advisor-alert-label { font-size: 0.78rem; font-weight: 700; margin-bottom: 2px; }
+.advisor-alert-sub { font-size: 0.65rem; color: var(--text-muted); }
+
+/* Intel + Today blocks */
+.cmd-intel {
+  grid-column: 1; grid-row: 2;
+  padding: 12px;
+  display: flex; flex-direction: column; justify-content: center;
+}
+.intel-text { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.5; }
+.intel-source { margin-top: 6px; font-size: 0.6rem; color: var(--text-muted); font-family: var(--font-display); letter-spacing: 0.5px; }
+
+.cmd-today-tasks { grid-column: 1; grid-row: 3; overflow-y: auto; scrollbar-width: none; }
+.cmd-today-tasks::-webkit-scrollbar { display: none; }
+.cmd-today-tasks .card { height: 100%; display: flex; flex-direction: column; }
+.task-list-scroll { flex: 1; overflow-y: auto; scrollbar-width: none; }
+.task-list-scroll::-webkit-scrollbar { display: none; }
+
+.task-row {
+  display: flex; align-items: center; gap: 8px;
+  padding: 8px 10px;
+  background: var(--bg-surface);
+  border: 1px solid var(--border-subtle);
+  border-radius: var(--radius-sm);
+  margin-bottom: 5px;
+  transition: var(--transition);
+}
+.task-row:hover { border-color: var(--border-glow); }
+.task-row.completed { opacity: 0.35; }
+.task-row.completed .task-name { text-decoration: line-through; }
+.task-color { width: 3px; height: 28px; border-radius: 2px; flex-shrink: 0; }
+.task-info { flex: 1; min-width: 0; }
+.task-name { font-size: 0.75rem; font-weight: 700; }
+.task-meta { font-size: 0.6rem; color: var(--text-muted); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
+.task-duration { font-size: 0.65rem; font-weight: 700; color: var(--text-secondary); font-family: var(--font-display); }
+.task-actions { display: flex; gap: 4px; }
+
+/* Quick launch buttons */
+.quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
+.quick-btn {
+  padding: 6px 8px;
+  background: var(--bg-surface);
+  border: 1px solid var(--border-subtle);
+  border-radius: var(--radius-sm);
+  font-size: 0.62rem; font-weight: 700;
+  color: var(--text-secondary);
+  text-align: center;
+  transition: var(--transition);
+  font-family: var(--font-display);
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+}
+.quick-btn:hover { border-color: var(--accent-1); color: var(--accent-1); box-shadow: var(--glow-1); }
+
+/* ============================================================
+   PLANNER (zero-scroll)
+   ============================================================ */
+.planner-wrap { flex: 1; display: flex; flex-direction: column; gap: 8px; min-height: 0; overflow: hidden; }
+.planner-header { display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
+.planner-grid-wrap { flex: 1; overflow: hidden; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); }
+.planner-grid {
+  display: grid;
+  grid-template-columns: 64px repeat(7, 1fr);
+  grid-template-rows: auto repeat(4, 1fr);
+  height: 100%;
+  gap: 1px;
+  background: var(--border-subtle);
+}
+.planner-time-label {
+  background: var(--bg-panel); padding: 6px 4px;
+  font-family: var(--font-display);
+  font-size: 0.55rem; font-weight: 700; color: var(--text-muted);
+  text-align: center;
+  display: flex; align-items: center; justify-content: center;
+  text-transform: uppercase; letter-spacing: 1px;
+}
+.planner-day-header {
+  background: var(--bg-panel); padding: 6px;
+  text-align: center;
+  font-family: var(--font-display);
+  font-size: 0.65rem; font-weight: 900;
+  color: var(--text-secondary);
+  text-transform: uppercase; letter-spacing: 1px;
+}
+.planner-day-header.today { color: var(--accent-1); }
+.planner-cell {
+  background: var(--bg-surface);
+  padding: 3px;
+  transition: var(--transition);
+  overflow: hidden;
+}
+.planner-cell:hover { background: rgba(255,255,255,0.02); }
+.planner-cell.drag-over { background: rgba(255,255,255,0.06); outline: 2px dashed var(--accent-1); outline-offset: -2px; }
+.planner-block {
+  padding: 4px 6px;
+  border-radius: 4px;
+  font-size: 0.58rem; font-weight: 700;
+  cursor: grab;
+  margin-bottom: 2px;
+  border-left: 3px solid;
+  transition: var(--transition);
+  font-family: var(--font-display);
+  text-transform: uppercase;
+  letter-spacing: 0.3px;
+}
