+/* NAV */
+function go(id){
+  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
+  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
+  const s=document.getElementById('section-'+id);if(s)s.classList.add('active');
+  const b=document.querySelector('.nav-btn[data-section="'+id+'"]');if(b)b.classList.add('active');
+}
