-    function computeLongestStreak(rows = []) {
-      const days = [...new Set(rows.map((row) => String(row.submitted_at || '').slice(0, 10)).filter(Boolean))].sort();
-      let longest = 0;
-      let run = 0;
-      let prev = null;
