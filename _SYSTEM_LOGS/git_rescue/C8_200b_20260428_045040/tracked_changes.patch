-    async function uploadBlobChunked(blob) {
-      const signed = await apiJson('/api/dboc/upload-url', {
-        method: 'POST',
-        headers: { 'Content-Type': 'application/json' },
-        body: JSON.stringify({ user_id: state.userId, filename: `dboc_${Date.now()}.webm` }),
-      });
-
-      const signedUrl = String(signed.signed_url || '').trim();
-      if (!signedUrl) throw new Error('signed_url_missing');
-
-      const total = blob.size;
-      const parts = Math.max(1, Math.ceil(total / CHUNK_SIZE));
-      let uploaded = 0;
-
-      for (let index = 0; index < parts; index += 1) {
-        const start = index * CHUNK_SIZE;
-        const endExclusive = Math.min(start + CHUNK_SIZE, total);
-        const endInclusive = Math.max(start, endExclusive - 1);
-        const chunk = blob.slice(start, endExclusive);
-        const chunkUrl = `${signedUrl}${signedUrl.includes('?') ? '&' : '?'}part=${index + 1}&parts=${parts}`;
-
-        let success = false;
-        for (let attempt = 0; attempt < RETRY_DELAYS_MS.length; attempt += 1) {
-          try {
-            await waitOnline();
-            const response = await fetch(chunkUrl, {
-              method: 'PUT',
-              headers: {
-                'Content-Type': 'application/octet-stream',
-                'Content-Range': `bytes ${start}-${endInclusive}/${total}`,
-              },
-              body: chunk,
-            });
-            if (!response.ok) throw new Error(`upload_http_${response.status}`);
-            success = true;
-            break;
-          } catch (error) {
-            if (attempt === RETRY_DELAYS_MS.length - 1) throw error;
-            setUploadProgress((uploaded / total) * 100, `Retrying upload (${attempt + 2}/3)...`);
-            await sleep(RETRY_DELAYS_MS[attempt]);
-          }
-        }
-
-        if (!success) throw new Error('chunk_upload_failed');
-        uploaded += chunk.size;
-        const pct = Math.round((uploaded / total) * 100);
-        setUploadProgress(pct, `Uploading... ${pct}%`);
-      }
-
-      return signedUrl.split('?')[0] || signedUrl;
-    }
