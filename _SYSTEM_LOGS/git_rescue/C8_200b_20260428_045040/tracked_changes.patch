+  {d:3,s:0,tp:'Renal',ty:'Study',dur:'30m',c:'var(--mastery-critical)',g:0},{d:3,s:1,tp:'Peds',ty:'Review',dur:'20m',c:'var(--mastery-stable)',g:0},
+  {d:3,s:2,tp:'OB/GYN',ty:'Review',dur:'15m',c:'var(--mastery-strong)',g:0},{d:4,s:0,tp:'Cardio',ty:'STAT',dur:'25m',c:'var(--mastery-weak)',g:0},
