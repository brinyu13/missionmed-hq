-      const ctx = canvas.getContext('2d');
-      if (!ctx) return;
-
-      const width = canvas.width;
-      const height = canvas.height;
-      ctx.clearRect(0, 0, width, height);
-
-      ctx.strokeStyle = 'rgba(100, 150, 220, 0.1)';
-      ctx.lineWidth = 1;
-      const rows = 5;
-      const cols = 8;
-      for (let row = 0; row <= rows; row += 1) {
-        const y = (row / rows) * height;
-        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(width, y); ctx.stroke();
-      }
-      for (let col = 0; col <= cols; col += 1) {
-        const x = (col / cols) * width;
-        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, height); ctx.stroke();
-      }
-
-      const series = state.delivery.pitchSeries;
-      if (!series.length) return;
-
-      ctx.strokeStyle = '#FF2D9C';
-      ctx.lineWidth = 2;
-      ctx.shadowColor = 'rgba(255, 45, 156, 0.4)';
-      ctx.shadowBlur = 6;
-      ctx.beginPath();
-      const maxPoints = 800;
-      const baseX = width / Math.max(1, maxPoints - 1);
-      series.forEach((point, index) => {
-        const hz = clamp(Number(point.hz || 0), 50, 400);
-        const normalizedY = (hz - 50) / 350;
-        const x = index * baseX;
-        const y = height - (normalizedY * height);
-        if (index === 0) ctx.moveTo(x, y);
-        else ctx.lineTo(x, y);
-      });
-      ctx.stroke();
-      ctx.shadowBlur = 0;
-    }
