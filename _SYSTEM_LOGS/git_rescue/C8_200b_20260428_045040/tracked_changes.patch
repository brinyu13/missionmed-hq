-    function detectPitchAutoCorrelation(samples, sampleRate) {
-      const size = samples.length;
-      if (size < 2) return { frequency: 0, confidence: 0 };
-
-      let rms = 0;
-      for (let index = 0; index < size; index += 1) {
-        const value = samples[index] || 0;
-        rms += value * value;
-      }
-      rms = Math.sqrt(rms / size);
-      if (rms < 0.01) return { frequency: 0, confidence: 0 };
-
-      const minLag = Math.floor(sampleRate / 400);
-      const maxLag = Math.floor(sampleRate / 50);
-      let bestLag = 0;
-      let bestCorr = 0;
-
-      for (let lag = minLag; lag <= maxLag; lag += 1) {
-        let corr = 0;
-        let normA = 0;
-        let normB = 0;
-        for (let i = 0; i + lag < size; i += 1) {
-          const a = samples[i];
-          const b = samples[i + lag];
-          corr += a * b;
-          normA += a * a;
-          normB += b * b;
-        }
-        const denom = Math.sqrt(normA * normB);
-        if (!denom) continue;
-        const normalized = corr / denom;
-        if (normalized > bestCorr) {
-          bestCorr = normalized;
-          bestLag = lag;
-        }
-      }
-
-      if (!bestLag) return { frequency: 0, confidence: 0 };
-      const frequency = sampleRate / bestLag;
-      if (frequency < 50 || frequency > 400) return { frequency: 0, confidence: 0 };
-      return { frequency, confidence: clamp(bestCorr, 0, 1) };
-    }
