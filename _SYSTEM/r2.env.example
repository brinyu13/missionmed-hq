# MissionMed R2 credentials template (non-secret).
# Copy to: /Users/brianb/MissionMed/_SYSTEM/r2.env
# Keep r2.env local-only (gitignored). Never commit secrets.
#
# Required:
# - R2_ACCESS_KEY_ID
# - R2_SECRET_ACCESS_KEY
# - R2_BUCKET
# - One of: R2_ENDPOINT_URL OR R2_ACCOUNT_ID
#
# Optional:
# - R2_REGION (default: auto)
# - R2_CDN_BASE_URL (must stay: https://cdn.missionmedinstitute.com)

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=missionmed-videos
R2_ENDPOINT_URL=
R2_ACCOUNT_ID=
R2_REGION=auto
R2_CDN_BASE_URL=https://cdn.missionmedinstitute.com

# Optional Cloudflare purge credentials used by deploy.sh
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
